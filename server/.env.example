# Copy to .env and fill in. .env is gitignored.

# Anthropic API key — powers the Charlybot chatbot (Claude Haiku 4.5).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Outlook credentials used by nodemailer for the contact form.
MAIL=
MAIL_PW=

# Optional: override the port the API listens on (defaults to 3000).
PORT=3000
